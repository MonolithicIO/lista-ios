    "alert.complete_list.message" : {
      "comment" : "Message for complete list confirmation alert",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Completing a list will mark all items as done. Once completed a list cannot be edited. Undo this action before making changes."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Completar una lista marcará todos los elementos como hechos. Una vez completada, una lista no se puede editar. Deshaga esta acción antes de hacer cambios."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Completar uma lista marcará todos os itens como concluídos. Uma vez completada, uma lista não pode ser editada. Desfaça esta ação antes de fazer alterações."
          }
        }
      }
    },
